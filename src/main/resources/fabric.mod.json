{
  "schemaVersion": 1,
  "id": "ditox_first_mod",
  "version": "${version}",
  "name": "RiserJuices",
  "description": "RiserJuices agrega frutas, cultivos, arboles, jugos, bebidas especiales y crafteos para Minecraft moderno. La version 1.7.0 expande el mod con uvas, naranja, manzana verde, coco, pina, frutilla, arandanos, platano, cerezas, mango y bebidas con efectos utiles.",
  "authors": [
    "DitoxSoft"
  ],
  "contributors": [
    "Fixxs"
  ],
  "license": "MIT",
  "icon": "assets/ditox_first_mod/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.ditoxsoft.ditoxfirstmod.DitoxFirstMod"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.ditoxsoft.ditoxfirstmod.client.DitoxFirstModClient"
      }
    ]
  },
  "mixins": [
    "ditox_first_mod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}
